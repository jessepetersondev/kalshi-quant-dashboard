{
  "name": "kalshi-quant-dashboard",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.6.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "db:migrate": "tsx packages/db/src/migrate.ts",
    "db:seed": "tsx packages/db/src/seed.ts",
    "dev": "tsx scripts/dev.ts",
    "format": "prettier --check .",
    "lint": "eslint .",
    "release:promote": "tsx scripts/release/promote.ts",
    "release:verify-staging": "tsx scripts/release/verify-staging.ts",
    "test": "tsx scripts/test.ts unit",
    "test:contract": "tsx scripts/test.ts contract",
    "test:e2e": "tsx scripts/test.ts e2e",
    "test:integration": "tsx scripts/test.ts integration",
    "test:smoke": "tsx scripts/test.ts smoke",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "@types/amqplib": "^0.10.7",
    "@commitlint/cli": "^19.8.0",
    "@commitlint/config-conventional": "^19.8.0",
    "@eslint/js": "^9.22.0",
    "@playwright/test": "^1.52.0",
    "eslint": "^9.22.0",
    "globals": "^15.15.0",
    "js-yaml": "^4.1.1",
    "prettier": "^3.5.3",
    "tsx": "^4.19.3",
    "turbo": "^2.4.4",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.26.1",
    "vitest": "^3.0.8"
  }
}
