{
  "name": "@kalshi-quant-dashboard/source-adapters",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/source-adapters/src/index.d.ts",
      "import": "./dist/source-adapters/src/index.js"
    }
  },
  "dependencies": {
    "@kalshi-quant-dashboard/config": "workspace:*",
    "@kalshi-quant-dashboard/contracts": "workspace:*"
  },
  "scripts": {
    "build": "tsx ../../scripts/clean-dist.ts && tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch --preserveWatchOutput",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  }
}
